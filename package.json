{
  "name": "cc-bot-lite",
  "version": "1.0.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "main": "build/main.js",
  "scripts": {
    "build": "tsc",
    "dev": "NODE_OPTIONS='--experimental-specifier-resolution=node' node --loader ts-node/esm/transpile-only --require tsconfig-paths/register src/main.ts",
    "start": "node build/main.js",
    "watch": "nodemon --exec npm run dev --watch src --ext ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check": "npm run format:check && npm run lint && npm run build",
    "preinstall": "node scripts/safe-chain-check.js"
  },
  "dependencies": {
    "@discordx/importer": "1.3.3",
    "@discordx/pagination": "4.4.0",
    "axios": "1.14.0",
    "discord.js": "14.26.2",
    "discordx": "11.13.3",
    "dotenv": "17.4.0"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.2",
    "eslint": "10.2.0",
    "eslint-config-prettier": "10.1.8",
    "nodemon": "3.1.14",
    "prettier": "3.8.1",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.2",
    "typescript-eslint": "8.58.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "npm": ">=10.0.0"
  }
}
